{
  "version": 2,
  "framework": null,
  "buildCommand": "npm run build",
  "functions": {
    "api/index.ts": {
      "includeFiles": [
        "node_modules/swagger-ui-dist/**",
        "docs/postman-curl-mapping.md"
      ]
    }
  },
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/api/index"
    }
  ]
}
